{
  "name": "vita-rppg-monitor",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc -b && vite build",
    "app:sync": "npm run build && cap sync",
    "android:open": "npm run app:sync && cap open android",
    "android:run": "npm run app:sync && cap run android",
    "android:apk": "npm run app:sync && cd android && gradlew.bat assembleDebug",
    "android:bundle": "npm run app:sync && cd android && gradlew.bat bundleRelease",
    "doctor": "powershell -ExecutionPolicy Bypass -File scripts/camera-doctor.ps1",
    "preview": "vite preview --host 127.0.0.1"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/app": "^8.1.0",
    "@capacitor/core": "^8.4.1",
    "@capacitor/haptics": "^8.0.2",
    "@capacitor/splash-screen": "^8.0.1",
    "@capacitor/status-bar": "^8.0.2",
    "@mediapipe/tasks-vision": "^0.10.35",
    "gsap": "^3.15.0",
    "lenis": "^1.3.25",
    "lucide-react": "^1.23.0",
    "p5": "^2.3.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.185.0",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.11"
  }
}
